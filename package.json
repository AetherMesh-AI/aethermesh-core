{
  "name": "aethermesh-desktop-workspace",
  "version": "0.1.0-alpha.0",
  "private": true,
  "description": "Desktop launcher workspace for AetherMesh.",
  "author": "AetherMesh AI",
  "main": "desktop/src/main.js",
  "scripts": {
    "desktop:dev": "electron desktop/src/main.js",
    "runtime:build": "node desktop/scripts/build-runtime.js",
    "runtime:copy": "node desktop/scripts/copy-runtime.js",
    "desktop:build": "npm run runtime:copy && electron-builder --config desktop/electron-builder.json",
    "desktop:build:mac": "npm run runtime:copy && electron-builder --mac --config desktop/electron-builder.json",
    "desktop:build:win": "npm run runtime:copy && electron-builder --win --config desktop/electron-builder.json",
    "desktop:build:linux": "npm run runtime:copy && electron-builder --linux --config desktop/electron-builder.json",
    "desktop:clean": "node desktop/scripts/clean.js",
    "test:desktop": "node --test desktop/tests/*.test.js"
  },
  "devDependencies": {
    "electron": "^43.0.0",
    "electron-builder": "^26.0.12"
  }
}
