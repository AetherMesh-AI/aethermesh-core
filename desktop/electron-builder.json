{
  "appId": "ai.aethermesh.desktop",
  "productName": "AetherMesh",
  "directories": {
    "output": "dist/desktop"
  },
  "files": [
    "desktop/src/**/*",
    "desktop/package.json"
  ],
  "extraResources": [
    {
      "from": "desktop/resources/runtime",
      "to": "runtime"
    }
  ],
  "mac": {
    "target": ["dmg"],
    "category": "public.app-category.developer-tools",
    "identity": "-"
  },
  "win": {
    "target": ["nsis"]
  },
  "linux": {
    "target": ["deb"],
    "category": "Development",
    "maintainer": "AetherMesh AI <releases@aethermesh.ai>"
  }
}
